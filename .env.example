# ===================================================
# SourcePilot Backend - Environment Variables
# ===================================================
# Copy this file to `.env` and fill in real values.

# --- Server ---
PORT=5000
NODE_ENV=development

# --- DeepSeek API ---
# Get a key at: https://platform.deepseek.com/apikeys
# DeepSeek is OpenAI-compatible; we hit it via plain fetch.
# The reasoning model (deepseek-v4-pro) needs a generous max_tokens budget
# (~270 tokens spent on internal reasoning before the visible answer).
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-v4-pro

# --- Supabase ---
# Get URL and anon key from your Supabase project settings.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here

# --- CORS ---
# Comma-separated list of allowed origins. Use * for development only.
CORS_ORIGIN=http://localhost:5173
