{
  "name": "sourcepilot-backend",
  "version": "0.1.0",
  "description": "SourcePilot backend — turns client requests into versioned, traceable project blueprints. Generates specs and other workflow artifacts using DeepSeek AI, exposed via REST API and MCP server.",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "mcp": "ts-node src/mcp/server.ts",
    "mcp:dev": "ts-node-dev --respawn --transpile-only src/mcp/server.ts",
    "typecheck": "tsc --noEmit",
    "test:deepseek": "ts-node scripts/test-deepseek.ts",
    "test:deepseek-models": "ts-node scripts/test-deepseek-models.ts"
  },
  "keywords": [
    "sourcepilot",
    "spec-driven",
    "deepseek",
    "supabase",
    "mcp"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@supabase/supabase-js": "^2.45.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "p-limit": "^3.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.4",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.2"
  }
}
