{
  "name": "ai-software-planning-assistant-backend",
  "version": "0.1.0",
  "description": "Backend for AI Powered Software Planning Assistant MVP - generates software plans/specifications from project ideas using Gemini AI, exposed via REST API and MCP server.",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "mcp": "ts-node src/mcp/server.ts",
    "mcp:dev": "ts-node-dev --respawn --transpile-only src/mcp/server.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ai-software-planning-assistant",
    "mcp",
    "gemini",
    "supabase",
    "mvc"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@supabase/supabase-js": "^2.45.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.4",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.2"
  }
}
